}

.stat-luxury-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--marol-gradient);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.stat-luxury-card:hover::before {
    transform: scaleX(1);
}

.stat-luxury-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 80px rgba(0,0,0,0.12);
}

.stat-luxury-number {
    font-size: 3rem;
