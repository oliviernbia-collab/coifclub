@push('scripts')
<script>
document.addEventListener('DOMContentLoaded', function () {
    // Hero slideshow (simple, non-Bootstrap fallback)
    const carousel = document.getElementById('heroSlideshow');
    if (carousel) {
        const items = Array.from(carousel.querySelectorAll('.carousel-item'));
        if (items.length > 0) {
            let cur = items.findIndex(i => i.classList.contains('active'));
            if (cur < 0) cur = 0;
            const goTo = (n) => {
                items[cur].classList.remove('active');
                cur = (n + items.length) % items.length;
                items[cur].classList.add('active');
            };
            let timer = setInterval(() => goTo(cur + 1), 5500);
            carousel.addEventListener('mouseenter', () => clearInterval(timer));
            carousel.addEventListener('mouseleave', () => { clearInterval(timer); timer = setInterval(() => goTo(cur + 1), 5500); });
        }
    }

    // Simple scroll reveal for elements using .fade-in-up
    const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                const el = e.target;
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
                el.style.transition = 'opacity .7s ease, transform .7s ease';
                io.unobserve(el);
            }
        });
    }, { threshold: 0.12 });

    document.querySelectorAll('.fade-in-up').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        io.observe(el);
    });
});
</script>
