/* =======================
   GALLERY SECTION - PREMIUM
======================= */
.gallery-premium {
    background: var(--marol-white);
    padding: 100px 0;
}

.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.gallery-item {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    transition: all 0.4s ease;
    cursor: pointer;
}

.gallery-item:hover {
